---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About the Bearing Witness Project">
  <div class="page">
    <h1>About</h1>
    <p>Content coming soon.</p>
  </div>
</Layout>

<style>
  .page {
    max-width: 68ch;
    margin: 0 auto;
    padding: 5rem var(--page-pad) 6rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.8;
  }
  h1 {
    font-family: var(--sans);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }
</style>
