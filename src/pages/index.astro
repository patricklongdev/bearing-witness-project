---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);

const CATEGORIES = [
  {
    name: 'Aboriginal Rights',
    description: "The projects in this section engage with the history, ongoing struggle, and legal recognition of Indigenous peoples' rights in Canada.",
    featured: {
      image: '/assets/2024/06/Rachel_Garrett_05-1.jpg',
      title: 'Resurgence',
      artist: 'Rachel Garrett',
      year: '2021',
      link: '/projects/resurgence/',
      quote: '“Changing the medium in which legal analysis is presented permits us to describe some of the projects in the Archive not only as eloquent and elegant but also beautiful.”',
    },
  },
  {
    name: 'Treaty Rights',
    description: 'The projects in this section address the history and interpretation of treaty-making across centuries and jurisdictions.',
    featured: {
      image: '/assets/2025/02/Krista_Johanson_01.jpg',
      title: 'Treaty of Lancaster, June, 1744',
      artist: 'Krista Johanson',
      year: '2009',
      link: '/projects/treaty-of-lancaster-june-1744/',
      quote: '"Reading the published transcripts exposes a rich vein of intercultural communication — one that Canadian lawyers and judges have only now begun to discover."',
    },
  },
  {
    name: "Prisoners' Rights",
    description: 'The projects in this section explore the contemporary realities of imprisonment in Canada — the overrepresentation of Indigenous peoples, the experience of women in prison, and the continuing legacy of colonialism within the carceral system.',
    featured: {
      image: '/assets/2016/06/Heather_Burley_01a.jpg',
      title: 'Freedom Flaunted',
      artist: 'Heather Burley',
      year: '2016',
      link: '/projects/freedom-flaunted/',
      quote: '"Students have told me that the visit to Matsqui or Kent was the most enduring memory of their three years of law school."',
    },
  },
];
---

<Layout title="Life of Law as Art Project" description="An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada, curated by Professor Michael Jackson, KC.">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Curated by Professor Michael Jackson, KC</p>
      <h1 class="hero-title">Life of Law<br />as Art</h1>
      <p class="hero-desc">An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada.</p>
      <a href="#thesis" class="scroll-cue" aria-label="Scroll to content">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="thesis" id="thesis">
    <div class="thesis-inner">
      <blockquote class="pull-quote">
        <p>Traditionally, we see art as apart from law — that is, we understand law as something other than artistic expression and vice versa. Once you start looking at law through the lens of creative expression, it quickly becomes apparent that art is not at the periphery but rather something core to law as a field of study and as a profession.</p>
        <footer class="pull-quote-attr">Lorne Sossin, Dean of Osgoode Hall Law School</footer>
      </blockquote>
    </div>
  </section>

  <section class="intro">
    <div class="intro-inner">
      <p>The students in these seminars, through their creative work, have opened their own minds to the contemporary realities of Indigenous rights and imprisonment in Canada, and in sharing it through this Archive, opened windows for the rest of us. The over 120 works collected here span the spectrum of artistic endeavour and include paintings, collages, sculptures, lithographs, poetry, illustrated stories, weavings, embroidered tapestries, photo essays, documentary videos, ceramics, beading, jewellery, choreographed dances, original songs and music. Each work is accompanied by curatorial commentary situating it in its legal and historical context.</p>
      <nav class="intro-cats" aria-label="Browse by category">
        <a href="/projects/?category=Aboriginal+Rights" class="intro-cat-link">Aboriginal Rights</a>
        <span class="intro-cat-sep" aria-hidden="true">·</span>
        <a href="/projects/?category=Treaty+Rights" class="intro-cat-link">Treaty Rights</a>
        <span class="intro-cat-sep" aria-hidden="true">·</span>
        <a href="/projects/?category=Prisoners%27+Rights" class="intro-cat-link">Prisoners' Rights</a>
      </nav>
    </div>
  </section>

  {CATEGORIES.map((cat, i) => (
    <section class="cat-section">
      <div class="cat-header">
        <h2 class="cat-name">{cat.name}</h2>
        <p class="cat-desc">{cat.description}</p>
      </div>
      <div class={`feat-block${i % 2 === 1 ? ' img-right' : ''}`}>
        <div class="feat-block-img">
          <img src={cat.featured.image} alt={cat.featured.title} loading="lazy" />
        </div>
        <div class="feat-block-text">
          <h3 class="feat-project-title">{cat.featured.title}</h3>
          <p class="feat-project-meta">{cat.featured.artist} · {cat.featured.year}</p>
          <p class="feat-quote">{cat.featured.quote}</p>
          <a href={cat.featured.link} class="cat-link">View this project →</a>
        </div>
      </div>
      <div class="cat-footer">
        <a href={`/projects/?category=${encodeURIComponent(cat.name)}`} class="cat-link">
          All {cat.name} projects →
        </a>
      </div>
    </section>
  ))}

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    border-bottom: 1px solid var(--border);
    padding: 8rem var(--page-pad) 6rem;
  }

  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: 'Source Serif 4 Display', 'Source Serif 4', Georgia, serif;
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 500;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .hero-desc {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--muted);
    line-height: 1.6;
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(5px); opacity: 0.9; }
  }

  .scroll-cue {
    display: inline-flex;
    color: var(--muted);
    text-decoration: none;
    margin-top: 2rem;
    animation: scroll-bob 2.2s ease-in-out infinite;
    transition: color 0.15s;
  }
  .scroll-cue:hover { color: var(--ink); }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; opacity: 0.5; }
  }

  /* ── Thesis / Sossin quote ── */
  .thesis {
    border-bottom: 1px solid var(--border);
    padding: 7rem var(--page-pad);
  }

  .thesis-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .pull-quote {
    max-width: 52ch;
    margin: 0 auto;
    text-align: center;
  }

  .pull-quote p {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.55;
    color: var(--ink);
    margin-bottom: 1.75rem;
  }

  .pull-quote-attr {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Introduction ── */
  .intro {
    padding: 6rem var(--page-pad);
    max-width: var(--max);
    margin: 0 auto;
  }

  .intro-inner {
    max-width: 60ch;
  }

  .intro-inner p {
    font-family: var(--serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink);
    margin-bottom: 1.2em;
  }

  .intro-cats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.6rem;
    margin-top: 1.25rem;
  }

  .intro-cat-link {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .intro-cat-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .intro-cat-sep {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }

  /* ── Category sections ── */
  .cat-section {
    padding: 4rem var(--page-pad) 5rem;
    max-width: var(--max);
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .cat-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .cat-name {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: normal;
    color: var(--ink);
    line-height: 1.2;
  }

  .cat-desc {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 55ch;
  }

  /* ── Featured block ── */
  .feat-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .feat-block.img-right .feat-block-img { order: 2; }
  .feat-block.img-right .feat-block-text { order: 1; }

  .feat-block-img {
    overflow: hidden;
    background: #e8e4e0;
    aspect-ratio: 4 / 3;
  }

  .feat-block-img img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .feat-block-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feat-project-title {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: normal;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
  }

  .feat-project-meta {
    font-family: var(--sans);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin: 0;
  }

  .feat-quote {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: var(--ink);
    margin: 0.5rem 0;
  }

  /* ── Shared link style ── */
  .cat-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
    align-self: flex-start;
  }
  .cat-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Category footer link ── */
  .cat-footer {
    margin-top: 0;
    text-align: right;
  }
  .cat-footer .cat-link { align-self: auto; }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .hero {
      min-height: calc(100svh - 65px);
      padding: 5rem var(--page-pad) 4rem;
      display: flex;
      flex-direction: column;
    }
    .hero-inner {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .hero-title {
      order: 1;
      font-size: 20vw;
      margin-bottom: 0;
    }
    .hero-label { display: none; }
    .hero-desc {
      order: 3;
      font-size: 1rem;
      line-height: 1.45;
      margin-top: 1.5rem;
      margin-bottom: 0;
    }
    .scroll-cue {
      order: 4;
      margin-top: auto;
      padding-top: 2rem;
    }

    .cat-header { grid-template-columns: 1fr; gap: 0.75rem; }

    .feat-block,
    .feat-block.img-right {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .feat-block.img-right .feat-block-img { order: 0; }
    .feat-block.img-right .feat-block-text { order: 1; }
  }
</style>
