---
interface Image {
  src: string;
  alt?: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
const id = `slideshow-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="slideshow" id={id}>
  <div class="slideshow-viewport">
    <div class="slideshow-track">
      {images.map((img, i) => (
        <figure class="slideshow-slide">
          <img
            src={img.src}
            alt={img.alt || ""}
            loading={i === 0 ? "eager" : "lazy"}
          />
        </figure>
      ))}
    </div>
  </div>

  {images.length > 1 && (
    <div class="slideshow-controls">
      <button class="prev" aria-label="Previous slide">←</button>
      <span class="counter"><span class="current">1</span> of {images.length}</span>
      <button class="next" aria-label="Next slide">→</button>
    </div>
  )}
</div>

<script define:vars={{ id }}>
  const root = document.getElementById(id);
  if (root) {
    const track   = root.querySelector(".slideshow-track");
    const slides  = root.querySelectorAll(".slideshow-slide");
    const counter = root.querySelector(".current");
    let current   = 0;

    function goTo(n) {
      current = (n + slides.length) % slides.length;
      track.style.transform = `translateX(-${current * 100}%)`;
      if (counter) counter.textContent = current + 1;
      // Eager-load the next image
      const next = slides[current + 1];
      if (next) { const img = next.querySelector("img"); if (img) img.loading = "eager"; }
    }

    root.querySelector(".prev")?.addEventListener("click", () => goTo(current - 1));
    root.querySelector(".next")?.addEventListener("click", () => goTo(current + 1));

    // Swipe support
    let startX = 0;
    const vp = root.querySelector(".slideshow-viewport");
    vp.addEventListener("pointerdown", (e) => { startX = e.clientX; });
    vp.addEventListener("pointerup",   (e) => {
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    });
  }
</script>

<style>
  .slideshow {
    margin: 1.5rem 0;
  }

  .slideshow-viewport {
    overflow: hidden;
  }

  .slideshow-track {
    display: flex;
    transition: transform 0.35s ease;
    will-change: transform;
  }

  .slideshow-slide {
    flex: 0 0 100%;
    margin: 0;
  }

  .slideshow-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Controls ── */
  .slideshow-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
  }

  .slideshow-controls button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.55rem 0.65rem;
    font-size: 0.7rem;
    font-family: var(--sans);
    color: var(--muted);
    line-height: 1;
    transition: color 0.15s;
  }
  .slideshow-controls button:hover { color: var(--ink); }

  .counter {
    font-size: 0.7rem;
    font-family: var(--sans);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
</style>
