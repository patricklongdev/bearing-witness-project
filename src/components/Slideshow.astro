---
interface Image {
  src: string;
  alt?: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
const id = `slideshow-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="slideshow" id={id}>
  <div class="slideshow-track">
    {images.map((img, i) => (
      <figure class="slideshow-slide">
        <img
          src={img.src}
          alt={img.alt || ""}
          loading={i === 0 ? "eager" : "lazy"}
        />
      </figure>
    ))}
  </div>

  {images.length > 1 && (
    <div class="slideshow-controls">
      <button class="prev" aria-label="Previous slide">←</button>
      <div class="slideshow-dots">
        {images.map((_, i) => (
          <span class={`dot${i === 0 ? ' is-active' : ''}`} />
        ))}
      </div>
      <span class="counter"><span class="current">1</span> of {images.length}</span>
      <button class="next" aria-label="Next slide">→</button>
    </div>
  )}
</div>

<script define:vars={{ id }}>
  const root = document.getElementById(id);
  if (root) {
    const track   = root.querySelector(".slideshow-track");
    const slides  = root.querySelectorAll(".slideshow-slide");
    const dots    = root.querySelectorAll(".dot");
    const counter = root.querySelector(".current");
    let current   = 0;

    function goTo(n) {
      current = (n + slides.length) % slides.length;
      track.scrollTo({ left: slides[current].offsetLeft, behavior: "smooth" });
      dots.forEach((d, i) => d.classList.toggle("is-active", i === current));
      if (counter) counter.textContent = current + 1;
    }

    root.querySelector(".prev")?.addEventListener("click", () => goTo(current - 1));
    root.querySelector(".next")?.addEventListener("click", () => goTo(current + 1));

    // Sync dots and counter on manual scroll / swipe
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const idx = Array.from(slides).indexOf(e.target);
            if (idx !== -1) {
              dots.forEach((d, i) => d.classList.toggle("is-active", i === idx));
              if (counter) counter.textContent = idx + 1;
            }
          }
        });
      },
      { root: track, threshold: 0.6 }
    );
    slides.forEach((s) => observer.observe(s));
  }
</script>

<style>
  .slideshow {
    margin: 1.5rem 0;
  }

  .slideshow-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 0;
    scrollbar-width: none;
  }
  .slideshow-track::-webkit-scrollbar { display: none; }

  .slideshow-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    margin: 0;
  }

  .slideshow-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Controls ── */
  .slideshow-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
  }

  .slideshow-controls button {
    background: none;
    border: none;
    cursor: pointer;
    /* generous touch target, small visible glyph */
    padding: 0.55rem 0.65rem;
    font-size: 0.7rem;
    font-family: var(--sans);
    color: var(--muted);
    line-height: 1;
    transition: color 0.15s;
  }
  .slideshow-controls button:hover { color: var(--ink); }

  /* ── Dots ── */
  .slideshow-dots {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .dot.is-active { background: var(--ink); }

  .counter {
    font-size: 0.7rem;
    font-family: var(--sans);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
</style>
