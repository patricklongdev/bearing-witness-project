---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);

const CATEGORIES = [
  {
    name: 'Aboriginal Rights',
    description: 'The projects in this section engage with the history, ongoing struggle, and legal recognition of Indigenous peoples\' rights in Canada. Students have responded through an extraordinary range of creative forms — from ceremonial textiles invoking Haida tradition, to illustrated legal histories, to works that draw directly on family and community experience.',
    nav: 'Indigenous rights, title, and sovereignty',
  },
  {
    name: 'Treaty Rights',
    description: 'The projects in this section address the history and interpretation of treaty-making across centuries and jurisdictions. Students have reproduced ceremonial diplomatic instruments, produced illustrated commentaries on historical and modern treaties, and drawn on their own experience as citizens of Indigenous treaty nations or as non-Indigenous Canadians growing up on treaty land.',
    nav: 'The history and interpretation of treaty-making',
  },
  {
    name: "Prisoners' Rights",
    description: 'The projects in this section explore the contemporary realities of imprisonment in Canada — the overrepresentation of Indigenous peoples, the experience of women in prison, and the continuing legacy of colonialism within the carceral system. Students have responded through work that takes us inside experiences that reports and commissions of inquiry cannot fully reach.',
    nav: 'Incarceration, reform, and the carceral system',
  },
];

const featured = Object.fromEntries(
  CATEGORIES.map(cat => [
    cat.name,
    allProjects.filter(p => p.data.category === cat.name).slice(0, 3),
  ])
);
---

<Layout title="Life of Law as Art Project" description="An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada, curated by Professor Michael Jackson, KC.">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Curated by Professor Michael Jackson, KC</p>
      <h1 class="hero-title">Life of Law<br />as Art</h1>
      <p class="hero-desc">An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada.</p>
      <a href="/about/" class="hero-intro-link">Begin with the introduction →</a>
    </div>
  </section>

  <section class="thesis">
    <div class="thesis-inner">
      <blockquote class="pull-quote">
        <p>Traditionally, we see art as apart from law — that is, we understand law as something other than artistic expression and vice versa. Once you start looking at law through the lens of creative expression, it quickly becomes apparent that art is not at the periphery but rather something core to law as a field of study and as a profession.</p>
        <footer class="pull-quote-attr">Lorne Sossin, Dean of Osgoode Hall Law School</footer>
      </blockquote>
    </div>
  </section>

  <section class="intro">
    <div class="intro-inner">
      <p>The students in these seminars, through their creative work, have opened their own minds to the contemporary realities of Indigenous rights and imprisonment in Canada, and in sharing it through this Archive, opened windows for the rest of us. The over 120 works collected here span the spectrum of artistic endeavour and include paintings, collages, sculptures, lithographs, poetry, illustrated stories, weavings, embroidered tapestries, photo essays, documentary videos, ceramics, beading, jewellery, choreographed dances, original songs and music. Each work is accompanied by curatorial commentary situating it in its legal and historical context.</p>
      <a href="/about/" class="intro-link">Learn more about the Archive →</a>
    </div>
  </section>

  <nav class="cat-nav" aria-label="Browse by category">
    {CATEGORIES.map(cat => (
      <a href={`/projects/?category=${encodeURIComponent(cat.name)}`} class="cat-nav-item">
        <span class="cat-nav-name">{cat.name}</span>
        <span class="cat-nav-desc">{cat.nav}</span>
      </a>
    ))}
  </nav>

  {CATEGORIES.map(cat => (
    <section class="cat-section">
      <div class="cat-header">
        <h2 class="cat-name">{cat.name}</h2>
        <p class="cat-desc">{cat.description}</p>
      </div>
      <div class="cat-grid">
        {featured[cat.name].map(project => (
          <a href={`/projects/${project.slug}/`} class="feat-card">
            <div class="feat-thumb">
              {project.data.thumbnail
                ? <img src={project.data.thumbnail} alt={project.data.title} loading="lazy" />
                : <div class="feat-thumb-placeholder" />}
            </div>
            <div class="feat-info">
              <h3 class="feat-title">{project.data.title}</h3>
              <p class="feat-meta">
                {project.data.author && <span>{project.data.author}</span>}
                {project.data.author && project.data.year && <span class="sep">·</span>}
                {project.data.year && <span>{project.data.year}</span>}
              </p>
            </div>
          </a>
        ))}
      </div>
      <div class="cat-footer">
        <a href={`/projects/?category=${encodeURIComponent(cat.name)}`} class="cat-link">
          All {cat.name} projects →
        </a>
      </div>
    </section>
  ))}

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    border-bottom: 1px solid var(--border);
    padding: 8rem var(--page-pad) 6rem;
  }

  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: 'Source Serif 4 Display', 'Source Serif 4', Georgia, serif;
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 500;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .hero-desc {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--muted);
    line-height: 1.6;
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  .hero-intro-link {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .hero-intro-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Thesis / Sossin quote ── */
  .thesis {
    border-bottom: 1px solid var(--border);
    padding: 7rem var(--page-pad);
  }

  .thesis-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .pull-quote {
    max-width: 52ch;
    margin: 0 auto;
    text-align: center;
  }

  .pull-quote p {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.55;
    color: var(--ink);
    margin-bottom: 1.75rem;
  }

  .pull-quote-attr {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Introduction ── */
  .intro {
    padding: 6rem var(--page-pad);
    max-width: var(--max);
    margin: 0 auto;
  }

  .intro-inner {
    max-width: 60ch;
  }

  .intro-inner p {
    font-family: var(--serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink);
    margin-bottom: 1.2em;
  }

  .intro-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    margin-top: 0.5rem;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .intro-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Three-way navigator ── */
  .cat-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--page-pad);
  }

  .cat-nav-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 2rem 0;
    text-decoration: none;
    color: var(--ink);
    border-right: 1px solid var(--border);
    padding-right: 2rem;
    transition: color 0.15s;
  }
  .cat-nav-item:last-child {
    border-right: none;
    padding-right: 0;
    padding-left: 2rem;
  }
  .cat-nav-item:nth-child(2) {
    padding-left: 2rem;
  }
  .cat-nav-item:hover { color: var(--accent); }

  .cat-nav-name {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: normal;
    line-height: 1.3;
  }

  .cat-nav-desc {
    font-family: var(--sans);
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.4;
    transition: color 0.15s;
  }
  .cat-nav-item:hover .cat-nav-desc { color: var(--accent); }

  @media (max-width: 600px) {
    .cat-nav {
      grid-template-columns: 1fr;
    }
    .cat-nav-item {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 0;
      padding-right: 0;
    }
    .cat-nav-item:last-child {
      border-bottom: none;
      padding-left: 0;
    }
    .cat-nav-item:nth-child(2) {
      padding-left: 0;
    }
  }

  /* ── Category sections ── */
  .cat-section {
    padding: 4rem var(--page-pad) 5rem;
    max-width: var(--max);
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .cat-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  @media (max-width: 700px) {
    .cat-header { grid-template-columns: 1fr; gap: 0.75rem; }
  }

  .cat-name {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: normal;
    color: var(--ink);
    line-height: 1.2;
  }

  .cat-desc {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 55ch;
  }

  /* ── Featured cards ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 800px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .cat-grid { grid-template-columns: 1fr; }
  }

  .feat-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
  }

  .feat-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e4e0;
    margin-bottom: 0.9rem;
  }

  .feat-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .feat-card:hover .feat-thumb img { transform: scale(1.04); }

  .feat-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e4e0;
  }

  .feat-info { padding: 0 0.1rem; }

  .feat-title {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: normal;
    line-height: 1.35;
    margin-bottom: 0.3rem;
    transition: color 0.15s;
  }
  .feat-card:hover .feat-title { color: var(--accent); }

  .feat-meta {
    font-size: 0.8rem;
    color: var(--muted);
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .sep { opacity: 0.4; }

  /* ── Category footer link ── */
  .cat-footer {
    margin-top: 2rem;
    text-align: right;
  }

  .cat-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .cat-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Mobile hero ── */
  @media (max-width: 700px) {
    .hero {
      min-height: calc(100svh - 65px);
      padding: 5rem var(--page-pad) 4rem;
      display: flex;
      flex-direction: column;
    }
    .hero-inner {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .hero-title {
      order: 1;
      font-size: 20vw;
      margin-bottom: 0;
    }
    .hero-label {
      display: none;
    }
    .hero-desc {
      order: 3;
      font-size: 1rem;
      line-height: 1.45;
      margin-top: 1.5rem;
      margin-bottom: 0;
    }
    .hero-intro-link {
      order: 4;
      margin-top: auto;
      padding-top: 2rem;
    }
  }
</style>
