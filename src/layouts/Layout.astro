---
interface Props {
  title: string;
  description?: string;
  thumbnail?: string;
  schema?: object;
}

const { title, description, thumbnail, schema } = Astro.props;
const siteName = 'Bearing Witness Project';
const siteUrl = 'https://bearingwitnessproject.ca';
const defaultDescription = 'An archive of student creative work exploring Indigenous rights, treaty law, and the rights of prisoners in Canada, curated by Professor Michael Jackson, OC, KC.';

const pageTitle = title === siteName ? title : `${title} — ${siteName}`;
const pageDescription = description || defaultDescription;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteUrl).toString();
const ogImage = thumbnail ? new URL(thumbnail, siteUrl).toString() : `${siteUrl}/images/og-default.jpg`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description: defaultDescription,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <link rel="icon" type="image/svg+xml" href="/images/mobile_logo.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
  </head>
  <body>
    <header>
      <a href="/" class="site-logo" aria-label={siteName}>
        <picture>
          <source media="(max-width: 640px)" srcset="/images/mobile_logo.svg" />
          <img src="/images/main_logo.svg" alt={siteName} width="240" height="72" />
        </picture>
      </a>
      <div class="nav-right">
        <nav class="site-nav" id="site-nav" aria-label="Main navigation">
          <a href="/projects/">Projects</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </nav>
        <button class="search-toggle" id="search-toggle" aria-label="Search" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="7.5" cy="7.5" r="5.5"/>
            <line x1="12" y1="12" x2="16.5" y2="16.5"/>
          </svg>
        </button>
        <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="2" y1="5"  x2="20" y2="5"/>
            <line x1="2" y1="11" x2="20" y2="11"/>
            <line x1="2" y1="17" x2="20" y2="17"/>
          </svg>
        </button>
      </div>

      <div class="search-overlay" id="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-modal">
          <div id="search"></div>
        </div>
      </div>
    </header>

    <div class="backdrop" id="backdrop" hidden></div>

    <main>
      <slot />
    </main>

    <footer>
      <p>A curated archive of student art projects exploring Indigenous rights and criminal justice by Professor Michael Jackson, OC, KC. &copy; 2026.</p>
    </footer>

    <script>
      const toggle        = document.getElementById('nav-toggle');
      const nav           = document.getElementById('site-nav');
      const backdrop      = document.getElementById('backdrop');
      const searchOverlay = document.getElementById('search-overlay');
      const searchToggle  = document.getElementById('search-toggle');
      let pagefindLoaded  = false;

      // ── Backdrop ──
      function showBackdrop() { if (backdrop) backdrop.hidden = false; }
      function hideBackdrop() { if (backdrop) backdrop.hidden = true; }

      // ── Internal silent close (no backdrop logic) ──
      function _closeNav() {
        nav?.classList.remove('is-open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.setAttribute('aria-label', 'Open menu');
      }
      function _closeSearch() {
        if (!searchOverlay) return;
        searchOverlay.hidden = true;
        searchToggle?.setAttribute('aria-expanded', 'false');
      }

      // ── Nav ──
      function openNav() {
        _closeSearch();
        nav?.classList.add('is-open');
        toggle?.setAttribute('aria-expanded', 'true');
        toggle?.setAttribute('aria-label', 'Close menu');
        showBackdrop();
      }
      function closeNav() {
        _closeNav();
        if (searchOverlay?.hidden !== false) hideBackdrop();
      }
      toggle?.addEventListener('click', () => {
        nav?.classList.contains('is-open') ? closeNav() : openNav();
      });

      // ── Search ──
      function openSearch() {
        if (!searchOverlay) return;
        _closeNav();
        searchOverlay.hidden = false;
        searchToggle?.setAttribute('aria-expanded', 'true');
        showBackdrop();

        if (!pagefindLoaded) {
          pagefindLoaded = true;
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = '/pagefind/pagefind-ui.css';
          document.head.appendChild(link);

          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = () => {
            new (window as any).PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
            setTimeout(() => {
              const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
              if (input) input.placeholder = 'Search archive';
            }, 50);
            focusInput();
          };
          document.head.appendChild(script);
        } else {
          focusInput();
        }
      }
      function focusInput() {
        setTimeout(() => {
          searchOverlay?.querySelector<HTMLInputElement>('input[type="text"]')?.focus();
        }, 60);
      }
      function closeSearch() {
        _closeSearch();
        if (!nav?.classList.contains('is-open')) hideBackdrop();
      }
      searchToggle?.addEventListener('click', () => {
        searchOverlay?.hidden ? openSearch() : closeSearch();
      });

      // ── Backdrop click closes everything ──
      backdrop?.addEventListener('click', () => {
        closeNav();
        closeSearch();
        hideBackdrop();
      });

      // ── Keyboard ──
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          closeNav();
          closeSearch();
          hideBackdrop();
          return;
        }
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  [hidden] { display: none !important; }

  .backdrop {
    position: fixed;
    inset: 0;
    background: rgba(250, 250, 248, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 50;
  }

  :root {
    --serif: Georgia, 'Times New Roman', serif;
    --sans: system-ui, -apple-system, sans-serif;
    --ink: #1a1a1a;
    --muted: #555;
    --border: #ddd;
    --bg: #fafaf8;
    --accent: #7a3b2e;
    --max: 72rem;
    --page-pad: clamp(1rem, 5vw, 3rem);
  }

  html { font-size: 16px; }

  body {
    font-family: var(--sans);
    color: var(--ink);
    background: var(--bg);
    line-height: 1.6;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  header {
    z-index: 60;
    position: relative;
    border-bottom: 1px solid var(--border);
    padding: 0.75rem var(--page-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    display: inline-block;
    line-height: 0;
  }
  .site-logo img {
    height: 3.825rem;
    width: auto;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .site-nav a {
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--ink);
    text-decoration: none;
  }
  .site-nav a:hover { color: var(--accent); }

  .search-toggle {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--ink);
    line-height: 0;
  }
  .search-toggle:hover { color: var(--accent); }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--ink);
    line-height: 0;
  }

  @media (max-width: 640px) {
    html { font-size: 17px; }
    .nav-toggle { display: flex; align-items: center; }
    .search-toggle svg { width: 22px; height: 22px; }
    .nav-toggle svg { width: 28px; height: 28px; }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 0;
      gap: 0;
      z-index: 100;
    }
    .site-nav.is-open { display: flex; }

    .site-nav a {
      font-size: 1.275rem;
      width: 100%;
      padding: 0.6rem var(--page-pad);
    }
  }

  main { flex: 1; }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem var(--page-pad);
    font-size: 0.8rem;
    color: var(--muted);
  }

  a { color: var(--ink); }
  a:hover { color: var(--accent); text-decoration: none; }

  img { max-width: 100%; height: auto; display: block; }

  .prose img { width: 100%; height: auto; display: block; }
  .prose figure { margin: 2em 0; }
  .prose figure img { width: 100%; }

  /* ── Search panel ── */
  .search-overlay {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    padding: 1.25rem var(--page-pad);
  }

  .search-modal {
    max-width: 38rem;
    margin: 0 auto;
  }

  /* Pagefind UI theme */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #999;
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: #f0ece6;
    --pagefind-ui-font: system-ui, -apple-system, sans-serif;
  }

  /* Borderless transparent input */
  .pagefind-ui__search-input {
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    padding-left: 2.25rem !important;
    font-size: 1.15rem !important;
    caret-color: var(--ink);
    caret-shape: bar;
  }
  .pagefind-ui__search-input:focus {
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
  }

  /* Larger icon, flush left, vertically centred */
  .pagefind-ui__form::before {
    width: 1.2rem !important;
    height: 1.2rem !important;
    top: 50% !important;
    left: 0 !important;
    transform: translateY(-50%) !important;
  }

  .pagefind-ui__search-clear { display: none !important; }
  .pagefind-ui__filter-panel { border: none !important; padding: 0 0.1rem !important; }
</style>
