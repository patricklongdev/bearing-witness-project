---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);

const CATEGORIES = [
  {
    name: 'Aboriginal Rights',
    description: 'The projects in this section engage with the history, ongoing struggle, and legal recognition of Indigenous peoples\' rights in Canada. Students have responded through an extraordinary range of creative forms — from ceremonial textiles invoking Haida tradition, to illustrated legal histories, to works that draw directly on family and community experience.',
  },
  {
    name: 'Treaty Rights',
    description: 'The projects in this section address the history and interpretation of treaty-making across centuries and jurisdictions. Students have reproduced ceremonial diplomatic instruments, produced illustrated commentaries on historical and modern treaties, and drawn on their own experience as citizens of Indigenous treaty nations or as non-Indigenous Canadians growing up on treaty land.',
  },
  {
    name: 'Prisoner Rights',
    description: 'The projects in this section explore the contemporary realities of imprisonment in Canada — the overrepresentation of Indigenous peoples, the experience of women in prison, and the continuing legacy of colonialism within the carceral system. Students have responded through work that takes us beyond the language of reports and commissions of inquiry.',
  },
];

const featured = Object.fromEntries(
  CATEGORIES.map(cat => [
    cat.name,
    allProjects.filter(p => p.data.category === cat.name).slice(0, 3),
  ])
);

const firstProject = allProjects[0];
---

<Layout title="Bearing Witness Project">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Curated by Professor Michael Jackson, OC, QC</p>
      <h1 class="hero-title">Bearing<br />Witness</h1>
      <p class="hero-desc">An archive of student creative work exploring Indigenous rights, treaty law, and the carceral state in Canada.</p>
      <a href={`/projects/${firstProject.slug}/`} class="hero-cta-mobile cta-btn">Start from the Beginning</a>
    </div>
  </section>

  <section class="intro">
    <div class="intro-inner">
      <p>The archive began in 1999 when Nadia Belokopitov, a member of the Haida Nation, asked whether she might respond to the seminar on First Nations and the Administration of Justice not with a traditional paper, but with a Northwest coast button blanket. Entering uncharted waters for the Law School, I welcomed her initiative. The result — Robes of Power — became both the first work in this archive and the inspiration for everything that followed.</p>
      <p>Through their creative work, students in these seminars have opened their own minds to the contemporary realities of Indigenous rights and imprisonment in Canada, and in sharing it through this archive, opened windows for the rest of us. The 127 works collected here — spanning beadwork, textile, photography, painting, essay, poetry, video, song, and more — bear witness to what becomes possible when law students are given permission to respond to injustice through art.</p>
      <a href="/projects/" class="intro-link">Browse all {allProjects.length} projects →</a>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-inner">
      <a href={`/projects/${firstProject.slug}/`} class="cta-btn">Start from the Beginning</a>
    </div>
  </section>

  {CATEGORIES.map(cat => (
    <section class="cat-section">
      <div class="cat-header">
        <h2 class="cat-name">{cat.name}</h2>
        <p class="cat-desc">{cat.description}</p>
      </div>
      <div class="cat-grid">
        {featured[cat.name].map(project => (
          <a href={`/projects/${project.slug}/`} class="feat-card">
            <div class="feat-thumb">
              {project.data.thumbnail
                ? <img src={project.data.thumbnail} alt={project.data.title} loading="lazy" />
                : <div class="feat-thumb-placeholder" />}
            </div>
            <div class="feat-info">
              <h3 class="feat-title">{project.data.title}</h3>
              <p class="feat-meta">
                {project.data.author && <span>{project.data.author}</span>}
                {project.data.author && project.data.year && <span class="sep">·</span>}
                {project.data.year && <span>{project.data.year}</span>}
              </p>
            </div>
          </a>
        ))}
      </div>
      <div class="cat-footer">
        <a href={`/projects/?category=${encodeURIComponent(cat.name)}`} class="cat-link">
          All {cat.name} projects →
        </a>
      </div>
    </section>
  ))}

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    border-bottom: 1px solid var(--border);
    padding: 8rem var(--page-pad) 6rem;
  }

  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: normal;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .hero-desc {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--muted);
    line-height: 1.6;
    max-width: 48ch;
  }

  /* ── Introduction ── */
  .intro {
    padding: 6rem var(--page-pad);
    max-width: var(--max);
    margin: 0 auto;
  }

  .intro-inner {
    max-width: 60ch;
    border-left: 2px solid var(--border);
    padding-left: 2rem;
  }

  .intro-inner p {
    font-family: var(--serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink);
    margin-bottom: 1.2em;
  }

  .intro-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ink);
    text-decoration: none;
    margin-top: 0.5rem;
  }
  .intro-link:hover { color: var(--accent); }

  /* ── Read the Archive CTA ── */
  .cta-section {
    padding: 1.5rem var(--page-pad) 5rem;
    max-width: var(--max);
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: normal;
    letter-spacing: 0.01em;
    color: #fff;
    background: var(--ink);
    text-decoration: none;
    padding: 0.9rem 2.5rem;
    border: 1px solid var(--ink);
    border-radius: 999px;
    transition: background 0.15s, color 0.15s;
  }
  .cta-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .cta-sub {
    font-size: 0.85rem;
    color: var(--muted);
    max-width: 40ch;
    line-height: 1.6;
  }

  /* ── Category sections ── */
  .cat-section {
    padding: 4rem var(--page-pad) 5rem;
    max-width: var(--max);
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .cat-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  @media (max-width: 700px) {
    .cat-header { grid-template-columns: 1fr; gap: 0.75rem; }
    .intro-inner { border-left: none; padding-left: 0; }
  }

  .cat-name {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: normal;
    color: var(--accent);
    line-height: 1.2;
  }

  .cat-desc {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 55ch;
  }

  /* ── Featured cards ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 800px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .cat-grid { grid-template-columns: 1fr; }
  }

  .feat-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
  }

  .feat-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e4e0;
    margin-bottom: 0.9rem;
  }

  .feat-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .feat-card:hover .feat-thumb img { transform: scale(1.04); }

  .feat-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e4e0;
  }

  .feat-info { padding: 0 0.1rem; }

  .feat-title {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: normal;
    line-height: 1.35;
    margin-bottom: 0.3rem;
    transition: color 0.15s;
  }
  .feat-card:hover .feat-title { color: var(--accent); }

  .feat-meta {
    font-size: 0.8rem;
    color: var(--muted);
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .sep { opacity: 0.4; }

  /* ── Category footer link ── */
  .cat-footer {
    margin-top: 2rem;
    text-align: right;
  }

  .cat-link {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .cat-link:hover { color: var(--ink); }

  /* ── First intro paragraph hidden on all sizes ── */
  .intro-inner p:first-child { display: none; }

  /* ── Hero CTA ── */
  .hero-cta-mobile {
    display: inline-block;
    margin-top: 2.5rem;
    align-self: flex-start;
  }
  .cta-section { display: none; }

  /* ── Mobile hero rework ── */
  @media (max-width: 700px) {
    .hero {
      min-height: calc(100svh - 65px);
      padding: 5rem var(--page-pad) 4rem;
      display: flex;
      flex-direction: column;
    }
    .hero-inner {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .hero-title {
      order: 1;
      font-size: 20vw;
      margin-bottom: 0;
    }
    .hero-label {
      display: none;
    }
    .hero-desc {
      order: 3;
      font-size: 1rem;
      line-height: 1.45;
      margin-top: 1.5rem;
      margin-bottom: 0;
    }
    .hero-cta-mobile {
      order: 4;
      margin-top: auto;
      padding-top: 2rem;
      font-size: 1rem;
      padding: 0.7rem 2rem;
      text-align: center;
    }
    .cta-section { display: none; }
  }
</style>
