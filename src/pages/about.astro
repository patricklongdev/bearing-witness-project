<script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script is:inline>
  var imgs = document.querySelectorAll('.prose img');
  imgs.forEach(function(img) {
    if (img.parentElement && img.parentElement.tagName === 'A') return;
    var a = document.createElement('a');
    a.href = img.src;
    a.className = 'glightbox';
    a.dataset.gallery = 'about-images';
    a.dataset.description = '';
    img.parentNode.insertBefore(a, img);
    a.appendChild(img);
  });

  var lb = GLightbox({
    selector: '.glightbox',
    touchNavigation: true,
    loop: false,
    zoomable: true,
  });

  // ── Custom zoom controls ──
  var zoomScale = 1;
  var ZOOM_STEP = 0.5;
  var ZOOM_MAX = 3;

  function getActiveImg() {
    var slide = document.querySelector('.gslide.current .gslide-image img');
    return slide || null;
  }

  function applyZoom(img) {
    img.style.transition = 'transform 0.2s ease';
    img.style.transform = zoomScale === 1 ? '' : 'scale(' + zoomScale + ')';
    img.style.transformOrigin = 'center center';
    img.style.cursor = zoomScale > 1 ? 'zoom-out' : 'zoom-in';
    var btn = document.getElementById('gl-zoom-out');
    if (btn) btn.disabled = zoomScale <= 1;
  }

  function injectZoomControls() {
    if (document.getElementById('gl-zoom-controls')) return;
    var controls = document.createElement('div');
    controls.id = 'gl-zoom-controls';
    controls.innerHTML =
      '<button id="gl-zoom-in"  aria-label="Zoom in">+</button>' +
      '<button id="gl-zoom-out" aria-label="Zoom out" disabled>−</button>';
    document.querySelector('.gcontainer')?.appendChild(controls);

    document.getElementById('gl-zoom-in').addEventListener('click', function(e) {
      e.stopPropagation();
      var img = getActiveImg();
      if (!img) return;
      zoomScale = Math.min(zoomScale + ZOOM_STEP, ZOOM_MAX);
      applyZoom(img);
    });
    document.getElementById('gl-zoom-out').addEventListener('click', function(e) {
      e.stopPropagation();
      var img = getActiveImg();
      if (!img) return;
      zoomScale = Math.max(zoomScale - ZOOM_STEP, 1);
      applyZoom(img);
    });
  }

  lb.on('open', function() {
    zoomScale = 1;
    setTimeout(injectZoomControls, 100);
  });

  lb.on('slide_changed', function() {
    zoomScale = 1;
    var img = getActiveImg();
    if (img) applyZoom(img);
  });

  lb.on('close', function() {
    zoomScale = 1;
    var el = document.getElementById('gl-zoom-controls');
    if (el) el.remove();
  });
</script>

<style>
  .page {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--page-pad) 6rem;
  }

  .prose {
    max-width: 68ch;
    margin: 0 auto;
    padding-top: 5rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--ink);
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: normal;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: bold;
    line-height: 1.3;
    color: var(--ink);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  blockquote {
    border-left: 2px solid var(--border);
    padding-left: 1.25rem;
    margin: 1.5em 0;
    color: var(--muted);
  }

  .section-rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 4rem 0 0;
  }

  p {
    color: var(--ink);
    margin-bottom: 1.2em;
  }

  img { cursor: zoom-in; }

  sup {
    font-size: 0.7em;
    line-height: 0;
  }

  .footnote-ref {
    color: var(--muted);
    text-decoration: none;
  }

  .footnotes {
    font-size: 0.78rem;
    color: var(--muted);
    font-family: var(--sans);
    margin-top: 2rem;
    line-height: 1.6;
  }

  .footnotes ol {
    padding-left: 1.2em;
    margin: 0;
  }

  .footnotes li { margin-bottom: 0.5em; }

  .footnotes a {
    color: var(--muted);
    text-underline-offset: 2px;
  }

  .footnote-backref { text-decoration: none; }

  :global(#gl-zoom-controls) {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 999;
  }

  :global(#gl-zoom-controls button) {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(0,0,0,0.5);
    color: #fff;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  :global(#gl-zoom-controls button:hover) {
    background: rgba(0,0,0,0.8);
  }

  :global(#gl-zoom-controls button:disabled) {
    opacity: 0.3;
    cursor: default;
  }
</style>
