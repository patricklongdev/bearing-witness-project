---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);

const CATEGORIES = [
  {
    name: 'Aboriginal Rights',
    description: "The projects in this section engage with the history, ongoing struggle, and legal recognition of Indigenous peoples' rights in Canada.",
    featured: {
      image: '/images/home_teaser_01.jpg',
      title: 'Resurgence',
      artist: 'Rachel Garrett',
      year: '2021',
      link: '/projects/resurgence/',
      quote: '“Changing the medium in which legal analysis is presented permits us to describe some of the projects in the Archive not only as eloquent and elegant but also beautiful.”',
    },
  },
  {
    name: 'Treaty Rights',
    description: 'The projects in this section address the history and interpretation of treaty-making across centuries and jurisdictions.',
    featured: {
      image: '/images/home_teaser_02.jpg',
      title: 'Treaty Identity: Moving beyond Legal Definitions',
      artist: 'Claire Stilwell',
      year: '2008',
      link: '/projects/treaty-identity-moving-beyond-legal-definitions/',
      quote: '“A remarkable synthesis, in canvas and text, spanning the long history of treaty-making in North America.”',
    },
  },
  {
    name: "Prisoners' Rights",
    description: 'The projects in this section explore the contemporary realities of imprisonment in Canada.',
    featured: {
      image: '/images/home_teaser_03.jpg',
      title: 'Corrections as Healing',
      artist: 'Leah Combs',
      year: '2017',
      link: '/projects/corrections-as-healing/',
      quote: '“Legal text is embedded and embodied in her sculpture and provides visual texture to the critical issues of mass incarceration of Indigenous peoples and some of the legal pathways that can help address and redress this continuing dark shadow of colonialism.”',
    },
  },
];
---

<Layout title="Life of Law as Art Project" description="An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada, curated by Professor Michael Jackson, KC.">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Curated by Professor Michael Jackson, KC</p>
      <h1 class="hero-title">Life of Law<br />as Art</h1>
      <p class="hero-desc">An archive of Allard Law School students' original artwork exploring the rights of Indigenous peoples and the rights of Prisoners in Canada.</p>
      <a href="#banner" class="scroll-cue" aria-label="Scroll to content">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </a>
    </div>
  </section>

  <div class="banner-outer" id="banner">
    <figure class="banner-inner">
      <picture>
        <source media="(min-width: 701px)" srcset="/images/desktop_hero_01.jpg" />
        <img
          src="/images/mobile_hero_01.jpg"
          width="553"
          height="369"
          loading="eager"
          fetchpriority="high"
          alt="Detail from Nadia Belokopitov's 'Robes of Power', a red-and-white Haida work showing totem figures, a forest treeline, and the spines of Canadian legal texts including the Criminal Code, the Indian Act, and the Constitution."
        />
      </picture>
      <figcaption class="banner-caption">Nadia Belokopitov, 1999</figcaption>
    </figure>
  </div>

  <section class="thesis" id="thesis">
    <div class="thesis-inner">
      <blockquote class="pull-quote">
        <span class="pull-quote-mark" aria-hidden="true">&ldquo;</span>
        <p>For most people, lawyers included, Law and Art lie at opposite ends of human imagination. The world’s great institutions of art leave us reinvigorated; the halls of justice much less so. Yet seen through the lens of artistic expression, Art opens us to new understanding of the Law in its broadest historical, political and cultural contexts.</p>
        <footer class="pull-quote-attr">Professor Michael Jackson</footer>
      </blockquote>
    </div>
  </section>

  <section class="intro">
    <div class="intro-inner">
      <p>Over more than two decades of seminars, law students have used artistic expression to engage the realities of Indigenous rights and imprisonment in Canada. Through their creative work they have opened their own minds to these realities and, in sharing it through the Archive, opened windows for the rest of us. Each piece in the Archive pairs the student’s own artist statement with Professor Jackson’s curatorial commentary situating the work in its broader context.</p>
      <a href="/about/" class="intro-link">Read Professor Jackson's full introduction →</a>
    </div>
  </section>

  {CATEGORIES.map((cat, i) => (
    <section class="cat-section">
      <div class="cat-inner">
        {i === 0 && <p class="section-lead">The Archive is organized in three parts, reflecting the themes of the seminars: Aboriginal Rights, Treaty Rights, and Prisoners' Rights.</p>}
        <div class="cat-header">
          <h2 class="cat-name">{cat.name}</h2>
          <p class="cat-desc">{cat.description}</p>
        </div>
        <div class="feat-block">
          <div class="feat-block-img">
            <img src={cat.featured.image} alt={cat.featured.title} loading="lazy" />
          </div>
          <div class="feat-block-text">
            <h3 class="feat-project-title">{cat.featured.title}</h3>
            <p class="feat-project-meta">{cat.featured.artist} · {cat.featured.year}</p>
            <p class="feat-quote">{cat.featured.quote}</p>
            <a href={cat.featured.link} class="cat-link">View this project →</a>
          </div>
        </div>
        <div class="cat-footer">
          <a href={`/projects/?category=${encodeURIComponent(cat.name)}`} class="cat-link">
            All {cat.name} projects →
          </a>
        </div>
      </div>
    </section>
  ))}

  <div class="closing-link-outer">
    <div class="closing-link-wrap">
      <a href="/projects/" class="closing-link">Browse the full Archive →</a>
    </div>
  </div>

  <script>
    document.querySelector('.scroll-cue')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('banner')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 8rem var(--page-pad) 0;
  }

  .hero-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding-bottom: 6rem;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: 'Source Serif 4 Display', 'Source Serif 4', Georgia, serif;
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 500;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 4rem;
  }

  .hero-desc {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--muted);
    line-height: 1.6;
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(5px); opacity: 0.9; }
  }

  .scroll-cue {
    display: block;
    width: fit-content;
    margin: 2.5rem auto 0;
    color: var(--muted);
    text-decoration: none;
    animation: scroll-bob 2.2s ease-in-out infinite;
    transition: color 0.15s;
  }
  .scroll-cue:hover { color: var(--ink); }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; opacity: 0.5; }
  }

  /* ── Homepage banner ── */
  .banner-outer {
    padding: 0 var(--page-pad) 2rem;
    scroll-margin-top: var(--header-h);
  }

  .banner-inner {
    max-width: var(--max);
    margin: 0 auto;
  }

  .banner-inner img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 553 / 369;
  }

  @media (min-width: 701px) {
    .banner-inner img {
      aspect-ratio: 2000 / 369;
    }
  }

  .banner-caption {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  /* ── Thesis / Sossin quote ── */
  .thesis {
    padding: 2.5rem var(--page-pad) 0;
  }

  .thesis-inner {
    max-width: var(--max);
    margin: 0 auto;
    border-bottom: 1px solid var(--border);
    padding-bottom: 4rem;
  }

  .pull-quote {
    max-width: 52ch;
    margin: 0 auto;
    text-align: center;
  }

  .pull-quote-mark {
    display: block;
    font-family: 'Source Serif 4 Display', 'Source Serif 4', Georgia, serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 1;
    color: var(--muted);
    opacity: 0.35;
    margin-bottom: -1rem;
  }

  .pull-quote p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.55;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .pull-quote-attr {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border-top: none;
    padding: 0;
  }

  /* ── Introduction ── */
  .intro {
    padding: 6rem var(--page-pad);
    max-width: var(--max);
    margin: 0 auto;
  }

  .intro-inner {
    max-width: 60ch;
  }

  .intro-inner p {
    font-family: var(--serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink);
    margin-bottom: 1.2em;
  }

  /* ── Intro link ── */
  .intro-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .intro-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Section lead-in ── */
  .section-lead {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  /* ── Closing invitation link ── */
  .closing-link-outer {
    padding: 0 var(--page-pad);
  }

  .closing-link-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 5rem 0 6rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .closing-link {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .closing-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Category sections ── */
  .cat-section {
    padding: 0 var(--page-pad) 5rem;
  }

  .cat-inner {
    max-width: var(--max);
    margin: 0 auto;
    border-top: 1px solid var(--border);
    padding-top: 4rem;
  }

  .cat-header {
    margin-bottom: 2.5rem;
  }

  .cat-name {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: normal;
    color: var(--ink);
    line-height: 1.2;
  }

  .cat-desc {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 55ch;
    margin-top: 0.5rem;
  }

  /* ── Featured block ── */
  .feat-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .feat-block-img {
    overflow: hidden;
    background: #e8e4e0;
    aspect-ratio: 4 / 3;
  }

  .feat-block-img img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .feat-block-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feat-project-title {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: normal;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
  }

  .feat-project-meta {
    font-family: var(--sans);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin: 0;
  }

  .feat-quote {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: var(--ink);
    margin: 0.5rem 0;
  }

  /* ── Shared link style ── */
  .cat-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: color 0.15s, text-decoration-color 0.15s;
    align-self: flex-start;
  }
  .cat-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ── Category footer link ── */
  .cat-footer {
    margin-top: 0;
    text-align: right;
  }
  .cat-footer .cat-link { align-self: auto; }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .hero {
      min-height: calc(100svh - var(--header-h));
      padding: 5rem var(--page-pad) 2rem;
      display: flex;
      flex-direction: column;
    }
    .hero-inner {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding-bottom: 1rem;
    }
    .hero-label {
      order: 0;
      display: block;
      margin-bottom: 1.5rem;
    }
    .hero-title {
      order: 1;
      font-size: 20vw;
      margin-bottom: 0;
    }
    .hero-desc {
      order: 3;
      font-size: 1rem;
      line-height: 1.45;
      margin-top: 1.5rem;
      margin-bottom: 0;
    }
    .scroll-cue {
      order: 4;
      margin-top: auto;
      margin-left: auto;
      margin-right: auto;
      padding-top: 3rem;
    }

    .feat-block {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .pull-quote {
      text-align: left;
    }
    .pull-quote-mark {
      text-align: left;
    }
    .pull-quote-attr {
      text-align: left;
    }
  }
</style>
